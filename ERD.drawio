        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    USERS {\n        bigint id PK\n        string name\n        string email UK\n        string password\n        enum role \&quot;admin|siswa\&quot;\n        timestamp email_verified_at\n        string remember_token\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    TAHUN_AJARAN {\n        bigint id PK\n        string tahun_ajaran\n        boolean is_active\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    GELOMBANG {\n        bigint id PK\n        bigint tahun_ajaran_id FK\n        string nama_gelombang\n        date tanggal_mulai\n        date tanggal_selesai\n        int kuota\n        enum status \&quot;aktif|nonaktif\&quot;\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    PENDAFTARAN {\n        bigint id PK\n        bigint user_id FK\n        bigint gelombang_id FK\n        string no_pendaftaran UK\n        date tanggal_daftar\n        enum status_pendaftaran \&quot;draft,menunggu_verifikasi,perlu_perbaikan,berkas_lengkap,lulus,tidak_lulus\&quot;\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    BIODATA_SISWA {\n        bigint id PK\n        bigint pendaftaran_id FK\n        string nisn\n        string nik\n        string nama_lengkap\n        string tempat_lahir\n        date tanggal_lahir\n        enum jenis_kelamin\n        string agama\n        text alamat\n        string desa\n        string kecamatan\n        string kabupaten\n        string provinsi\n        string kode_pos\n        string no_hp\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    DATA_ORANG_TUA {\n        bigint id PK\n        bigint pendaftaran_id FK\n\n        string nama_ayah\n        string nik_ayah\n        string pekerjaan_ayah\n        decimal penghasilan_ayah\n\n        string nama_ibu\n        string nik_ibu\n        string pekerjaan_ibu\n        decimal penghasilan_ibu\n\n        string no_hp\n        text alamat\n\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    ASAL_SEKOLAH {\n        bigint id PK\n        bigint pendaftaran_id FK\n        string nama_sekolah\n        string npsn\n        text alamat\n        int tahun_lulus\n        decimal rata_rata_nilai\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    BERKAS {\n        bigint id PK\n        bigint pendaftaran_id FK\n        enum jenis_berkas\n        string nama_file\n        string path_file\n        enum status \&quot;menunggu,diterima,perlu_perbaikan\&quot;\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    VERIFIKASI_BERKAS {\n        bigint id PK\n        bigint berkas_id FK\n        bigint admin_id FK\n        enum status \&quot;diterima,ditolak,perlu_perbaikan\&quot;\n        text catatan\n        datetime tanggal_verifikasi\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    SELEKSI {\n        bigint id PK\n        bigint pendaftaran_id FK\n        bigint admin_id FK\n        enum status \&quot;menunggu,lulus,tidak_lulus\&quot;\n        decimal nilai\n        text keterangan\n        datetime tanggal_seleksi\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    USERS ||--o{ PENDAFTARAN : melakukan\n    TAHUN_AJARAN ||--o{ GELOMBANG : memiliki\n    GELOMBANG ||--o{ PENDAFTARAN : membuka\n\n    PENDAFTARAN ||--|| BIODATA_SISWA : memiliki\n    PENDAFTARAN ||--|| DATA_ORANG_TUA : memiliki\n    PENDAFTARAN ||--|| ASAL_SEKOLAH : berasal_dari\n\n    PENDAFTARAN ||--o{ BERKAS : mengunggah\n    BERKAS ||--|| VERIFIKASI_BERKAS : diverifikasi\n\n    USERS ||--o{ VERIFIKASI_BERKAS : memverifikasi\n    USERS ||--o{ SELEKSI : menentukan\n\n    PENDAFTARAN ||--|| SELEKSI : hasil&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="whSc3wRGvELMWnmM4cfK-1">
